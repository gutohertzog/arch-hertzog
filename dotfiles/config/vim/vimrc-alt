" interface --------------------------------------------------------------- {{{
" ajustes importantes para o CMD
" Screen Background 0/0/0
" Screen Text 200/200/200
syntax on               " habilite realce de sintaxe
filetype plugin indent on
colorscheme desert      " cores para tema escuro desert, evening, ron, slate
set background=dark
set t_Co=256            " força 256 cores
set number              " mostra número das linhas
set relativenumber      " números relativos para navegação
set ruler               " mostra posição do cursor
