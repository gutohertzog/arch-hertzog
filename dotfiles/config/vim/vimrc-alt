" portátil & vintage ------------------------------------------------------ {{{
" essas variáveis vão determinar o que vai ser ativado em cada ambiente e as
" suas específicas configurações

" flags manuais
"   - 0 = arquivos portáteis
"   — 1 = arquivos locais
let s:is_portable = 0
"   - 0 = terminal moderno
"   — 1 = terminal antigo
let s:is_vintage = 0
" }}}

" ambiente ---------------------------------------------------------------- {{{
" flags para determinar o ambiente de execução
let s:is_unix    = has('unix')
let s:is_mac     = has('mac') || has('macunix')
let s:is_windows = has('win32') || has('win64')
let s:is_wsl = has('unix')
    \ && filereadable('/proc/version')
    \ && join(readfile('/proc/version')) =~? 'microsoft'
" }}}

" local vimrc ------------------------------------------------------------- {{{
" local de execução do vimrc
let s:vimrc_root = fnamemodify(resolve(expand('<sfile>:p')), ':h')

" local onde ficarão os diretórios para swap, undo, backup e info
call mkdir(s:vimrc_root . '/data',   'p')
let s:data_dir = s:vimrc_root . '/data'
" }}}

" arquivos temporários ---------------------------------------------------- {{{
call mkdir(s:data_dir . '/temporarios', 'p')
let $TEMP = s:data_dir . '/temporarios'
let $TMP  = s:data_dir . '/temporarios'
" }}}

