" interface --------------------------------------------------------------- {{{
syntax on               " habilite realce de sintaxe
filetype plugin indent on
set background=dark
set number              " mostra número das linhas
set relativenumber      " números relativos para navegação
set ruler               " mostra posição do cursor
set showcmd             " exibe comandos incompletos
set laststatus=2        " sempre mostra a barra de status
set colorcolumn=80,100
set scrolloff=3         " mantém 3 linhas de amrgem ao rolar
set sidescrolloff=0     " mantém 0 colunas de margem ao rolar
set showmatch           " brevemente indica o par
set splitbelow          " divide a tela para baixo
set splitright          " divide a tela para direita
set splitkeep=screen    " ao dividir, mantém o texto na mesma linha da tela
set conceallevel=0      " evita que caracteres fiquem invisíveis
set nolist              " desativa os caracteres de marcação
set nocursorcolumn      " deixa desativado o destaque da coluna do cursor
set matchpairs+=<:>     " amplia o funcionamento do % para mais pares
set showmode            " informativo do modo atual

if s:is_vintage
    " ajustes importantes para o CMD
    " Screen Background 0/0/0
    " Screen Text 200/200/200
    set t_Co=16         " define 16 cores
    set nocursorline    " desativa o destaque de linha
    " caracteres de marcação simples
    set showbreak=>\
    set listchars=tab:>-,eol:$,nbsp:_,space:.,trail:-,extends:>,precedes:<
else
    set t_Co=256        " define 256 cores
    set cursorline      " destaca a linha atual
    " remove o fundo e deixa apenas a linha
    highlight CursorLine cterm=underline ctermbg=NONE ctermfg=NONE
    " caracteres de marcação elaborados
    set showbreak=↪\
    set listchars=tab:<->,eol:↲,nbsp:║,space:␣,trail:•,extends:⟩,precedes:⟨
endif
" }}}

" backup swap undo -------------------------------------------------------- {{{
" cria os diretórios se não existirem
call mkdir(s:data_dir . '/swaps',   'p')
call mkdir(s:data_dir . '/backups', 'p')
call mkdir(s:data_dir . '/undos',   'p')
call mkdir(s:data_dir . '/viminfo', 'p')

" pastas
let s:backupdir = s:data_dir . '/backups//'
let s:undodir   = s:data_dir . '/undos//'
let s:swapdir   = s:data_dir . '/swaps//'
if exists('+shada')
    execute 'set shadafile=' . s:data_dir . '/viminfo/main.shada'
else
    execute 'set viminfofile=' . s:data_dir . '/viminfo/main.viminfo'
endif

" aplica as configurações
set backup      " habilita arquivos de backup (~)
execute 'set backupdir=' . s:backupdir

set undofile    " habilita histórico de undo persistente
set undolevels=1000
execute 'set undodir=' . s:undodir

set swapfile    " habilita swapfiles (.swp)
execute 'set directory=' . s:swapdir
" }}}

