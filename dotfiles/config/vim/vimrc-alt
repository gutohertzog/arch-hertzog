" vim-code-dark ----------------------------------------------------------- {{{
" https://github.com/tomasiser/vim-code-dark
let g:has_code_dark = isdirectory(g:plugins_dir . '/vim-code-dark')

if g:has_code_dark
    let g:codedark_transparent = 0
    let g:codedark_conservative = 0

    if s:is_vintage
        let g:codedark_modern = 0
        let g:codedark_italics = 0
    else
        set t_ut=
        set termguicolors
        let g:codedark_modern = 1
        let g:codedark_italics = 1
        highlight Comment gui=italic cterm=italic

        " necessário para sobreescrever os ajustes do tema
        augroup MyCodeDarkTweaks
            autocmd!
            autocmd ColorScheme codedark highlight Comment guifg=#696969
        augroup END
    endif

    let g:airline_theme = 'codedark'
    colorscheme codedark
endif
" }}}

