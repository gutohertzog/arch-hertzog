set statusline=global
set noshowmode          " mostra modo atual (normal, insert, etc)
set signcolumn=auto
set colorcolumn=80,100
set scrolloff=3         " mantém 3 linhas de amrgem ao rolar
set sidescrolloff=0     " mantém 0 colunas de margem ao rolar
set showmatch
set splitbelow          " divide a tela para baixo
set splitright          " divide a tela para direita
set splitkeep=screen    " ao dividir, mantém o texto na mesma linha da tela
set conceallevel=0      " evita que caracteres fiquem invisíveis
set showbreak=↪\
set listchars=tab:<->,eol:↲,nbsp:║,space:␣,trail:•,extends:⟩,precedes:⟨
set nolist

set matchpairs+=<:>     " amplia o funcionamento do % para mais pares
" remove o fundo do cursorline
set nocursorcolumn      " deixa desativado o destaque da coluna do cursor
set cursorline          " destaca a linha atual
" remove o fundo e deixa apenas a linha
highlight CursorLine cterm=underline ctermbg=NONE ctermfg=NONE
" }}}

" backup swap undo -------------------------------------------------------- {{{
" Dica: certifique-se de criar essas pastas antes de usar:
"   Linux :
"       - mkdir -p ~/.config/vim/backups
"       - mkdir -p ~/.config/vim/undo
"       - mkdir -p ~/.config/vim/swaps
"   Windows:
"       - mkdir %USERPROFILE%\vimfiles\backups
"       - mkdir %USERPROFILE%\vimfiles\undos
"       - mkdir %USERPROFILE%\vimfiles\swaps

set backup      " habilita arquivos de backup (~)
set undofile    " habilita histórico de undo persistente
set swapfile    " habilita swapfiles (.swp)
set undolevels=1000

" detecta SO
if has("win32") || has("win64")
    let s:vim_data = expand('~/vimfiles')       " Windows
else
    let s:vim_data = expand('~/.config/vim')    " Linux / Unix / macOS
endif

" pastas
let s:backupdir = s:vim_data . '/backups//'
let s:undodir   = s:vim_data . '/undos//'
let s:swapdir   = s:vim_data . '/swaps//'

" aplica as configurações
execute 'set backupdir=' . s:backupdir
execute 'set undodir='   . s:undodir
execute 'set directory=' . s:swapdir

if exists('+shada')
    execute 'set shadafile=' . s:vim_data . '/viminfo/main.shada'
else
    execute 'set viminfofile=' . s:vim_data . '/viminfo/main.viminfo'
endif
" }}}


