" RelNumToggle ------------------------------------------------------------ {{{
" ativa relativenumber no modo normal e desativa no modo insert
augroup RelNumToggle
    autocmd!
    autocmd InsertEnter * set norelativenumber
    autocmd InsertLeave * set relativenumber
augroup END
" é necessário já que <C-c> não dispara os eventos Insert Enter/Leave
inoremap <C-c> <Esc>:set relativenumber<CR>
" }}}

" AutoRead ---------------------------------------------------------------- {{{
" recarrega o arquivo se estiver sendo alterado em outro lugar
set autoread
augroup AutoRead
    autocmd!
    autocmd FocusGained,BufEnter * silent! checktime
augroup END
" }}}

" FormatOptions ----------------------------------------------------------- {{{
" evita inserir e formatar comentários automaticamente
augroup FormatOptions
    autocmd!
    autocmd FileType * setlocal
        \ formatoptions-=r
        \ formatoptions-=o
        \ formatoptions-=c
augroup END
" }}}

" WindowsFiles ------------------------------------------------------------ {{{
" define tipo dos para os arquivos do Windows
augroup WindowsFiles
    autocmd!
    autocmd BufNewFile,BufRead *.bat,*.cmd setlocal fileformat=dos
augroup END
" }}}

" FileTypeSettings -------------------------------------------------------- {{{
" ajustes individuais para cada tipo de arquivo
augroup FileTypeSettings
    autocmd!
    " Python: PEP8
    autocmd FileType python setlocal tabstop=4 shiftwidth=4 expandtab
    autocmd FileType python setlocal textwidth=79 colorcolumn=80,100

    " SQL:
    " desativa ctrl+c em arquivos sql
    " autocmd FileType sql setlocal noremap <buffer> <C-C> <Nop>
    " indentação menor
    autocmd FileType sql setlocal tabstop=2 shiftwidth=2 expandtab

    " PHP: padrão PSR-2
    autocmd FileType php setlocal tabstop=4 shiftwidth=4 expandtab

    " fecha o preview do omnicomplete automaticamente
    autocmd CompleteDone * silent! pclose
augroup END
" }}}

" RunCurrentPythonFile ---------------------------------------------------- {{{
" roda o arquivo python atual
augroup RunCurrentPythonFile
    autocmd!
    autocmd FileType python nnoremap <buffer> <F5> :w<CR>:bel term python %<CR>
augroup END
" }}}

