" https://github.com/junegunn/fzf.vim
let g:has_fzf = isdirectory(g:plugins_dir . '/fzf.vim')

if g:has_fzf
    let g:fzf_vim = {}
    " melhora a busca
    if executable('rg')
        set grepprg=rg\ --vimgrep\ --smart-case
        set grepformat=%f:%l:%c:%m
    endif
    if s:is_vintage
        let g:fzf_vim.preview_window = [] " desativa o preview completamente
    endif
    let g:fzf_command_prefix = 'Fzf'
    let g:fzf_layout = { 'down': '~60%' } " up | down | left | right
    let $FZF_DEFAULT_OPTS = '
        \ --border
        \ --cycle
        \ --layout=reverse
        \ --preview-window=right:60%:wrap
        \
        \ --bind ctrl-k:up
        \ --bind ctrl-j:down
        \ --bind ctrl-y:preview-up
        \ --bind ctrl-e:preview-down
        \ --bind ctrl-p:preview-half-page-up
        \ --bind ctrl-n:preview-half-page-down
        \ --bind ctrl-space:toggle-preview
        \ '


    if executable('fd')
        let $FZF_DEFAULT_COMMAND = '
            \ fd --type f --hidden --follow --exclude .git'
    endif
    if has('win32') || has('win64')
        let $RG_DEFAULT_OPTS = $RG_DEFAULT_OPTS . ' --no-color --no-heading'
    endif

    " desativa preview especificamente para BLines (buffer atual)
    command! -nargs=* -bang FzfBLinesNoPreview
        \ call fzf#vim#buffer_lines(
            \ <q-args>, {'options': '--no-preview'}, <bang>0)

    " atalhos {{{
    " busca arquivo
    nnoremap <Leader>ff :FzfFiles<CR>
    nnoremap <Leader>fF :FzfFiles!<CR>
    " busca palavra
    nnoremap <Leader>fw :FzfRg<Space>
    nnoremap <Leader>fW :FzfRg!<Space>
    " busca palavra sob cursor
    nnoremap <Leader>f/ :FzfRg <C-R><C-W><CR>
    " busca buffers abertos
    nnoremap <Leader>fb :FzfBuffers<CR>
    nnoremap <Leader>fB :FzfBuffers!<CR>
    " bsuca mapeamentos
    nnoremap <Leader>fm :FzfMaps<CR>
    nnoremap <Leader>fM :FzfMaps!<CR>
    " busca históricos de arquivos já abertos
    nnoremap <Leader>fh :FzfHistory<CR>
    nnoremap <Leader>fH :FzfHistory!<CR>
    " busca no histórico de buscas
    nnoremap <Leader>fs :FzfHistory/<CR>
    nnoremap <Leader>fS :FzfHistory/!<CR>
    " busca no histórico de comandos
    nnoremap <Leader>fc :FzfHistory:<CR>
    nnoremap <Leader>fC :FzfHistory!:<CR>
    " busca por linha no buffer atual
    nnoremap <Leader>fl :FzfBLinesNoPreview<CR>
    nnoremap <Leader>fL :FzfBLinesNoPreview!<CR>
    " abre o buscado
    let g:fzf_action = {
        \ 'ctrl-t': 'tab split',
        \ 'ctrl-x': 'split',
        \ 'ctrl-v': 'vsplit' }
    " }}}

    " cores {{{
    " herda as cores do Vim
    let g:fzf_colors = {
        \ 'fg':      ['fg', 'Normal'],
        \ 'bg':      ['bg', 'Normal'],
        \ 'hl':      ['fg', 'Comment'],
        \ 'fg+':     ['fg', 'CursorLine', 'CursorColumn', 'Normal'],
        \ 'bg+':     ['bg', 'CursorLine'],
        \ 'hl+':     ['fg', 'Statement'],
        \ 'info':    ['fg', 'PreProc'],
        \ 'prompt':  ['fg', 'Conditional'],
        \ 'pointer': ['fg', 'Exception'],
        \ 'marker':  ['fg', 'Keyword'],
        \ 'spinner': ['fg', 'Label'],
        \ 'header':  ['fg', 'Comment'] }
    " }}}
endif
" }}}

