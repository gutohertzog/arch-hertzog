" atualiza arquivo -------------------------------------------------------- {{{
" recarrega o arquivo se estiver sendo alterado em outro lugar
set autoread
augroup AuroRead
    autocmd!
    autocmd FocusGained,BufEnter * silent! checktime
augroup END
" }}}

" formato de texto -------------------------------------------------------- {{{
augroup FormatOptions
    autocmd!
    autocmd FileType * setlocal
        \ formatoptions-=r
        \ formatoptions-=o
        \ formatoptions-=c
augroup END
" }}}

" definições automáticas para tipos determinados -------------------------- {{{
augroup WindowsFiles
    autocmd!
    autocmd BufNewFile,BufRead *.bat,*.cmd setlocal fileformat=dos
augroup END
" }}}

" configurações por filetype ---------------------------------------------- {{{
augroup FileTypeSettings
    autocmd!
    " Python: PEP8
    autocmd FileType python setlocal tabstop=4 shiftwidth=4 expandtab
    autocmd FileType python setlocal textwidth=79 colorcolumn=80,100

    " SQL:
    " desativa ctrl+c em arquivos sql
    " autocmd FileType sql setlocal noremap <buffer> <C-C> <Nop>
    " indentação menor
    autocmd FileType sql setlocal tabstop=2 shiftwidth=2 expandtab

    " PHP: padrão PSR-2
    autocmd FileType php setlocal tabstop=4 shiftwidth=4 expandtab

    " fecha o preview do omnicomplete automaticamente
    autocmd CompleteDone * silent! pclose
augroup END
" }}}

" rodar arquivo atual ----------------------------------------------------- {{{
augroup RunCurrentFile
    autocmd!
    autocmd FileType python nnoremap <buffer> <F5> :w<CR>:bel term python %<CR>
augroup END
" }}}

" ajusta o fold para melhor desempenho ------------------------------------ {{{
augroup FastFoldLite
    autocmd!
    autocmd InsertEnter * setlocal foldmethod=manual
    autocmd InsertLeave * setlocal foldmethod=syntax | silent! normal! zx
augroup END
