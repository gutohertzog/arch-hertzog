" apaga todos exceto o atual
function! s:OnlyCurrentBuffer() abort
    let current = bufnr('%')

    for buf in range(1, bufnr('$'))
        if buflisted(buf) && buf != current
            execute 'bdelete ' . buf
        endif
    endfor
endfunction
nnoremap <Leader>bo :call <SID>OnlyCurrentBuffer()<CR>

" limpa termo buscado
