    " linters: analisam o código e reportam problemas no signcolumn
    let g:ale_linters = {
        \ 'python': ['flake8'],
        \ 'sql':    ['sqlfluff'],
        \ 'php':    ['phpcs'],
    \}

    " fixers: reformatam/corrigem o arquivo
    let g:ale_fixers = {
        \ 'python': ['black', 'isort'],
        \ 'sql':    ['sqlfluff'],
        \ 'php':    ['phpcbf'],
    \}

    " quando executar
    let g:ale_lint_on_text_changed = 'never' " não lint enquanto digita
    let g:ale_lint_on_insert_leave = 1       " lint ao sair do insert mode
    let g:ale_lint_on_save = 1               " lint ao salvar
    let g:ale_fix_on_save = 0                " fix NÃO automático (segurança)

    " python embarcado: aponta para o executável correto
    if g:is_windows
        let g:ale_python_executable = g:vimrc_root . '/../python/python.exe'
    endif
    " let g:ale_python_executable = resolve(
        " \ fnamemodify(g:vimrc_root, ':h') . '/python/python.exe')

    " aparência
    let g:ale_set_highlights = 0
    let g:ale_sign_column_always = 1
    let g:ale_sign_error = '>>'
    let g:ale_sign_warning = '--'
    let g:ale_echo_msg_error_str = 'E'
