" ambiente ---------------------------------------------------------------- {{{
" flags para determinar o ambiente de execução
let g:is_unix    = has('unix') " verdadeiro em Linux e macOS
let g:is_mac     = has('mac') || has('macunix') " específico para macOS
let g:is_windows = has('win32') || has('win64') " qualquer Windows
" WSL: Linux rodando dentro do Windows
let g:is_wsl = has('unix')
    \ && filereadable('/proc/version')
    \ && join(readfile('/proc/version')) =~? 'microsoft'
" }}}

" local vimrc ------------------------------------------------------------- {{{
" local de execução do vimrc
let g:vimrc_root = fnamemodify(resolve(expand('<sfile>:p')), ':h')

" local onde ficarão os diretórios para swap, undo, backup, temp, fzf e info
call mkdir(g:vimrc_root . '/data',   'p')
let g:data_dir = g:vimrc_root . '/data'
" }}}

" arquivos temporários ---------------------------------------------------- {{{
call mkdir(g:data_dir . '/temporarios', 'p')
" redireciona temp do Windows para pasta portátil
let $TEMP = g:data_dir . '/temporarios'
let $TMP  = g:data_dir . '/temporarios' " $TMP é a variante curta
" }}}

" runtime path ------------------------------------------------------------ {{{
" define o local de execução para o local do vimrc, ignorando vimfiles
" prioriza scripts da pasta portátil e adciona o diretório after ao final
execute 'set runtimepath^=' . g:vimrc_root
execute 'set runtimepath+=' . g:vimrc_root . '/after'

" packpath só é necessário quando os plugins estão na pasta pack
" com is_plug_active = 1, o plug gerencia tudo e o pack é ignorado
" também evita que um plugin seja carregado automaticamente do pack
" e pelo plug
if !g:is_plug_active
    " prioriza pacotes da pasta portátil
    execute 'set packpath^=' . g:vimrc_root
endif
" }}}

