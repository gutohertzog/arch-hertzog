        \ 'b' : ['FzfBuffers'          , 'listar buffers'],
        \ 'B' : ['FzfBuffers!'         , 'buffers (fullscreen)'],
        \ 'm' : ['FzfMaps'             , 'listar mapeamentos'],
        \ 'M' : ['FzfMaps!'            , 'mapeamentos (fullscreen)'],
        \ 'h' : ['FzfHistory'          , 'histórico de arquivos'],
        \ 'H' : ['FzfHistory!'         , 'histórico (fullscreen)'],
        \ 's' : ['FzfHistory/'         , 'histórico de buscas'],
        \ 'S' : ['FzfHistory/!'        , 'busca histórica (fullscreen)'],
        \ 'c' : ['FzfHistory:'         , 'histórico de comandos'],
        \ 'C' : ['FzfHistory:!'        , 'comandos (fullscreen)'],
        \ 'l' : ['FzfBLinesNoPreview'  , 'linhas no buffer atual'],
        \ 'L' : ['FzfBLinesNoPreview!' , 'linhas (fullscreen)'],
    \ }

    " categoria: NERDTree
    let g:which_key_map['e'] = [':NERDTreeToggle' , 'abrir/fechar NERDTree']
    let g:which_key_map['nf'] = [':NERDTreeFocus' , 'focar NERDTree']

    " registra o dicionário para o leader <Space>
    call which_key#register('<Space>', "g:which_key_map")
endif
