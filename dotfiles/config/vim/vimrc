" Trim Trailing Whitespace ------------------------------------------------ {{{
" remove os espaços em branco ao final da linha quando salva
function! s:TrimTrailingWhitespace() abort
    " salva posição do cursor e estado de rolagem
    let l:save = winsaveview()
    " remove trailing whitespace sem poluir o histórico de busca
    keeppatterns %s/\s\+$//e
    " restaura posição após a substituição
    call winrestview(l:save)
endfunction

augroup TrimWhitespace
    autocmd!
    autocmd BufWritePre * call s:TrimTrailingWhitespace()
augroup END
" }}}

